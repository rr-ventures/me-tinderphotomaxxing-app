{
  "name": "Dating Profile Photo Analyzer",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "pip install --no-cache-dir -r backend/requirements.txt && cd frontend && npm install",
  "postStartCommand": "bash \"${containerWorkspaceFolder}/scripts/ensure-dev-servers.sh\"",
  "postAttachCommand": "bash \"${containerWorkspaceFolder}/scripts/ensure-dev-servers.sh\"",
  "forwardPorts": [8000, 3000],
  "portsAttributes": {
    "3000": {
      "label": "Frontend (http://localhost:3000)",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8000": {
      "label": "Backend API",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "remote.autoForwardPorts": true,
        "remote.autoForwardPortsSource": "hybrid"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
